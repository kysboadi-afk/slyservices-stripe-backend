# Stripe
# Must start with sk_live_ (production) or sk_test_ (test mode)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# Must start with pk_live_ (production) or pk_test_ (test mode)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Frontend URL (used for CORS and Stripe redirect URLs)
FRONTEND_URL=https://your-frontend-url.com

# SMTP (Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_sending_email@gmail.com
SMTP_PASS=your_email_app_password

# Owner notification email
OWNER_EMAIL=SLYSERVICES@SUPPORTS-INFO.COM
